PORT=3000

# Auth (unused in local dev — auth is bypassed)
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRATION=1h

# Email — Gmail App Password flow
# Generate at: myaccount.google.com/apppasswords (requires 2FA)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx
EMAIL_FROM_NAME="Your Name from Apex"
# In production set this to your Railway URL — used for OAuth callbacks and tracking pixels
APP_URL=http://localhost:3000
# If your frontend is on a different origin than the API set this too (not needed on Railway)
# FRONTEND_URL=https://your-frontend.up.railway.app

# Microsoft SSO — shared Azure app credentials (set in Railway Variables, not per-user)
# Azure Portal → Entra ID → App Registrations → apex-bdr → Overview + Certificates & Secrets
MICROSOFT_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
MICROSOFT_CLIENT_SECRET=your-client-secret-value

# AI — Google Gemini (get key from console.cloud.google.com)
GEMINI_API_KEY=your_gemini_api_key
# Claude API key is stored in the DB via the Integrations page — not needed here

# Email send safety (protects your Gmail/Microsoft account from spam flags)
MAX_EMAILS_PER_DAY=200          # hard daily cap across all sequences
EMAIL_SEND_DELAY_MS=2000        # ms to wait between each send (avoids SMTP throttling)

# API rate limits (per-endpoint)
VOICE_CALL_LIMIT=10
VOICE_CALL_DURATION=60
EMAIL_LIMIT=20
EMAIL_DURATION=60
DIALING_LIMIT=20
DIALING_DURATION=300

# Azure Service Bus (optional — not needed for core email/call flow)
SERVICE_BUS_CONNECTION_STRING=your-service-bus-connection-string
SERVICE_BUS_QUEUE_NAME=your-service-bus-queue-name
