// This is your Prisma schema file,
// learn more about it in the Prisma docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}

model Prospect {
  id          Int      @id @default(autoincrement())
  firstName   String
  lastName    String
  email       String   @unique
  companyName String?
  status      String   @default("Uncontacted")
  createdAt   DateTime @default(now())
}

model Sequence {
  id        Int      @id @default(autoincrement())
  name      String
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  steps     SequenceStep[]
  createdAt DateTime @default(now())
}

model SequenceStep {
  id        Int      @id @default(autoincrement())
  sequenceId Int
  order     Int
  delayDays Int      @default(0)
  subject   String
  body      String
  sequence  Sequence @relation(fields: [sequenceId], references: [id])
}

model EmailActivity {
  id            Int      @id @default(autoincrement())
  userId        Int
  prospectId    Int
  sequenceStepId Int
  subject       String
  body          String
  status        String   @default("Pending")
  sentAt        DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id])
  prospect      Prospect @relation(fields: [prospectId], references: [id])
  sequenceStep  SequenceStep @relation(fields: [sequenceStepId], references: [id])
}
