{
  "name": "outreach-clone",
  "version": "1.0.0",
  "description": "Outreach clone backend server",
  "main": "index.js",
  "scripts": {
    "start": "npx prisma db push && node index.js",
    "dev": "nodemon index.js",
    "build": "cd frontend && npm install && npm run build",
    "railway:deploy": "npm run build && npx prisma migrate deploy",
    "postinstall": "prisma generate",
    "test": "dotenv -e .env.test -- npx prisma db push --skip-generate && dotenv -e .env.test -- jest"
  },
  "prisma": {
    "schema": "prisma/schema.prisma"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@aws-sdk/client-sqs": "^3.1016.0",
    "@azure/msal-node": "^5.1.1",
    "@azure/service-bus": "^7.9.5",
    "@google/genai": "^1.46.0",
    "@prisma/client": "^5.0.0",
    "amqplib": "^0.10.9",
    "aws-sdk": "^2.1693.0",
    "axios": "^1.13.6",
    "bcrypt": "^5.1.0",
    "body-parser": "^2.2.2",
    "broadway": "^4.1.0",
    "cors": "^2.8.6",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "fuzzysearch": "^1.0.3",
    "imapflow": "^1.3.1",
    "jsonwebtoken": "^9.0.0",
    "kafka-node": "^5.0.0",
    "kafkajs": "^2.2.4",
    "mailparser": "^3.9.8",
    "moment": "^2.30.1",
    "mongoose": "^9.3.2",
    "multer": "^2.1.1",
    "natural": "^8.1.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.3",
    "nodemailer-dkim": "^1.0.5",
    "openai": "^6.32.0",
    "pg": "^8.20.0",
    "prisma": "^5.0.0",
    "redis": "^5.11.0",
    "sequelize": "^6.37.8",
    "winston": "^3.19.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "jest": "^30.3.0",
    "nodemon": "^3.0.1",
    "supertest": "^7.2.2"
  }
}
